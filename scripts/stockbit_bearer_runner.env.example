# Salin file ini menjadi stockbit_bearer_runner.env bila Anda ingin
# menyimpan variabel lokal untuk helper scripts runner.

GITHUB_REPO_URL=https://github.com/OWNER/REPO
RUNNER_TOKEN=isi_registration_token_dari_github
RUNNER_NAME=stockbit-bearer-01
RUNNER_LABELS=stockbit-bearer,linux
RUNNER_DIR=$HOME/actions-runner-stockbit-bearer
RUNNER_VERSION=2.328.0

RUNNER_HOME=$HOME
PROFILE_ROOT=$HOME/.stockbit-bearer/profiles
REPO_WORKDIR=$HOME/stockbit-runner

